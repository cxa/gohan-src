# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'gohan' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )


  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = min_ios_version_supported
      end
    end
    # Fix missing/empty MinimumOSVersion in prebuilt framework Info.plists (e.g. hermesvm.framework).
    # PlistBuddy handles both binary and XML plist formats and is the Apple-blessed tool for this.
    ios_target = min_ios_version_supported
    Dir.glob("#{installer.sandbox.root}/**/*.framework/Info.plist").each do |plist_path|
      current = `/usr/libexec/PlistBuddy -c "Print :MinimumOSVersion" "#{plist_path}" 2>/dev/null`.strip
      next unless current.empty?
      system('/usr/libexec/PlistBuddy', '-c', "Add :MinimumOSVersion string #{ios_target}", plist_path,
             out: File::NULL, err: File::NULL)
    end
  end
end
